# URL Yeniden Yazma Motorunu Aktif Hale Getir
RewriteEngine On

# =================================================================
# EN ÖNEMLİ KURAL: Tüm HTTP trafiğini HTTPS'ye yönlendir.
# Bu kuralın diğer tüm kurallardan önce çalışması en iyisidir.
# =================================================================
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ÖNCELİKLİ KURALLAR (Spesifik olanlar önce gelir)
#----------------------------------------------------
# Sitemap
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# --- Yazı (Post) Sayfaları ---
# Eski URL'leri (.php'li veya .php'siz) yeniye 301 ile yönlendir.
RewriteCond %{THE_REQUEST} \s/post\.php\?slug=([^\s&]+)\s [NC]
RewriteRule ^ /yazi/%1? [R=301,L]
RewriteCond %{QUERY_STRING} ^slug=([^&]+)$
RewriteRule ^post/?$ /yazi/%1? [R=301,L]
# Yeni URL'yi (/yazi/...) çalıştır.
RewriteRule ^yazi/([a-zA-Z0-9\-]+)/?$ post.php?slug=$1 [L,QSA]

# --- Kategori Sayfaları ---
# Eski URL'leri (.php'li veya .php'siz) yeniye 301 ile yönlendir.
RewriteCond %{THE_REQUEST} \s/category\.php\?slug=([^\s&]+)\s [NC]
RewriteRule ^ /kategori/%1? [R=301,L]
RewriteCond %{QUERY_STRING} ^slug=([^&]+)$
RewriteRule ^category/?$ /kategori/%1? [R=301,L]
# Yeni URL'yi (/kategori/...) çalıştır.
RewriteRule ^kategori/([a-zA-Z0-9\-]+)/?$ category.php?slug=$1 [L,QSA]

# --- Arama (Search) Sayfaları ---
# Eski URL'leri (.php'li veya .php'siz) yeniye 301 ile yönlendir.
RewriteCond %{THE_REQUEST} \s/search\.php\?q=([^\s&]+)\s [NC]
RewriteRule ^ /arama/%1? [R=301,L]
RewriteCond %{QUERY_STRING} ^q=([^&]+)$
RewriteRule ^search/?$ /arama/%1? [R=301,L]
# Yeni URL'yi (/arama/...) çalıştır.
RewriteRule ^arama/([^/]+)/?$ search.php?q=$1 [L,QSA]

# --- Şifre Sıfırlama (Reset Password) Sayfaları ---
# Eski URL'leri (.php'li veya .php'siz) yeniye 301 ile yönlendir.
RewriteCond %{THE_REQUEST} \s/reset_password\.php\?token=([^\s&]+)\s [NC]
RewriteRule ^ /sifre-sifirla/%1? [R=301,L]
RewriteCond %{QUERY_STRING} ^token=([^&]+)$
RewriteRule ^reset_password/?$ /sifre-sifirla/%1? [R=301,L]
# Yeni URL'yi (/sifre-sifirla/...) çalıştır.
RewriteRule ^sifre-sifirla/([^/]+)/?$ reset_password.php?token=$1 [L,QSA]


# .PHP UZANTISINI GİZLEME (Statik Sayfalar İçin)
#----------------------------------------------------
# 1. Adım: Birisi adres çubuğuna "sayfa.php" yazarsa, onu kalıcı olarak "/sayfa" adresine yönlendir.
RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?]
RewriteRule ^ %1 [R=301,L]

# 2. Adım: Tarayıcıya "/sayfa" yazıldığında, arka planda "sayfa.php" dosyasını çalıştır.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*?)/?$ $1.php [L]
#----------------------------------------------------


# === Güvenlik Başlıkları ve Diğer Ayarlar (Değişiklik Yok) ===
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "no-referrer-when-downgrade"
    Header always set Permissions-Policy "geolocation=(), microphone=()"
</IfModule>

ErrorDocument 404 /404.html
Options -Indexes

<FilesMatch "\.(htaccess|env|log|ini|json|sh|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# BEGIN cPanel-generated php ini directives, do not edit
<IfModule php8_module>
   php_flag display_errors Off
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 128M
   php_value post_max_size 128M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php82"
   php_value upload_max_filesize 128M
   php_flag zlib.output_compression Off
</IfModule>
<IfModule lsapi_module>
   php_flag display_errors Off
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 128M
   php_value post_max_size 128M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php82"
   php_value upload_max_filesize 128M
   php_flag zlib.output_compression Off
</IfModule>
# END cPanel-generated php ini directives, do not edit

<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType application/x-shockwave-flash "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  <filesMatch "\.(ico|jpe?g|png|gif|swf)$">
    Header set Cache-Control "max-age=2592000, public"
  </filesMatch>
  <filesMatch "\.(css)$">
    Header set Cache-Control "max-age=2592000, public"
  </filesMatch>
  <filesMatch "\.(js)$">
    Header set Cache-Control "max-age=2592000, private"
  </filesMatch>
</IfModule>

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([a-zA-Z0-9-]+)$ page.php?slug=$1 [L,QSA]

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
